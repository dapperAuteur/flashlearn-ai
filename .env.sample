# =============================================================================
# FlashLearn AI — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values for local dev.
# In Vercel/production, set these in the project's Environment Variables UI.
#
# REQUIRED groups are flagged below. Others are optional or feature-gated
# (the app boots without them; specific features fail or no-op).
# =============================================================================

# ─── REQUIRED: Database ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/flashcard-ai

# ─── REQUIRED: NextAuth ──────────────────────────────────────────────────────
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# ─── REQUIRED: Gemini AI (per key type — at least PUBLIC for the public API) ─
# Each API-key type gets its own Gemini key so usage and rate limits are
# isolated across access tiers. PUBLIC is the most-used in production.
# ECOSYSTEM was added for cross-product consumers (Wanderlearn etc.); it can
# alias to GEMINI_API_KEY_PUBLIC initially.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY_PUBLIC=your-gemini-api-key
GEMINI_API_KEY_ADMIN=your-gemini-api-key
GEMINI_API_KEY_ADMIN_PUBLIC=your-gemini-api-key
GEMINI_API_KEY_APP=your-gemini-api-key
GEMINI_API_KEY_ECOSYSTEM=your-gemini-api-key
GEMINI_MODEL_NAME=gemini-2.0-flash

# ─── REQUIRED: Upstash Redis (rate limits, webhook milestone dedupe) ────────
# Either UPSTASH_REDIS_* or STORAGE_KV_* names work — STORAGE_KV_* is
# auto-injected by Vercel's Marketplace integration; UPSTASH_REDIS_* matches
# the standalone Upstash console naming. The code accepts either prefix.
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token
# STORAGE_KV_REST_API_URL=your-redis-url
# STORAGE_KV_REST_API_TOKEN=your-redis-token

# ─── REQUIRED for ecosystem webhooks: Upstash QStash ─────────────────────────
# Used for delayed session delivery and outbound webhook retry/backoff.
# Either QSTASH_* or UPSTASH_QSTASH_* names work — same pattern as Redis.
UPSTASH_QSTASH_URL=https://qstash.upstash.io
UPSTASH_QSTASH_TOKEN=your-qstash-token
UPSTASH_QSTASH_CURRENT_SIGNING_KEY=your-signing-key
UPSTASH_QSTASH_NEXT_SIGNING_KEY=your-next-signing-key
# QSTASH_TOKEN=your-qstash-token
# QSTASH_CURRENT_SIGNING_KEY=your-signing-key
# QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# ─── REQUIRED for ecosystem webhooks: signing-secret encryption ──────────────
# AES-256-GCM key that encrypts per-WebhookEndpoint signing secrets at rest.
# We must store secrets reversibly because the dispatcher signs outbound
# bodies with the same plaintext the consumer holds.
# Generate with: openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY=your-64-hex-char-encryption-key

# ─── REQUIRED for cron-triggered jobs ────────────────────────────────────────
# Bearer token Vercel Cron uses to authenticate calls to /api/cron/*
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ─── Stripe (billing) ────────────────────────────────────────────────────────
# Use TEST keys (sk_test_..., pk_test_...) for development and sandbox.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Subscription price IDs — create in Stripe Dashboard → Products
NEXT_PUBLIC_STRIPE_10_MONTHLY_PRICE=price_your-monthly-price-id
NEXT_PUBLIC_STRIPE_100_ANNUAL_PRICE=price_your-annual-price-id
NEXT_PUBLIC_STRIPE_100_LIFETIME_PRICE=price_your-lifetime-price-id
# API metered-billing prices (Developer + Pro tiers, overage usage)
STRIPE_API_DEVELOPER_PRICE_ID=price_your-developer-price-id
STRIPE_API_DEVELOPER_METER_EVENT_NAME=api_developer_overage
STRIPE_API_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_API_PRO_METER_EVENT_NAME=api_pro_overage

# ─── Email — choose ONE provider (SMTP via nodemailer OR Mailgun) ────────────
# SMTP (e.g. Gmail, Postmark, SES via SMTP, etc.):
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-username
EMAIL_SERVER_PASSWORD=your-smtp-password
EMAIL_SERVER_SECURE=false
EMAIL_FROM=noreply@yourdomain.com
# Mailgun (used by transactional + campaign sender):
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
# Where admin notifications (sign-ups, errors, etc.) are routed
ADMIN_NOTIFICATION_EMAIL=admin.flashlearnai@awews.com

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── Switchy (link shortener / pixel tracking) ───────────────────────────────
SWITCHY_API_TOKEN=your-switchy-token
SWITCHY_DOMAIN=your-shortlink-domain
# Comma-separated pixel IDs to attach to every shortlink
SWITCHY_PIXEL_IDS=

# ─── Self-API access (using the FlashLearn API from another tool) ────────────
# Issue a key from /developer/keys, then paste here for local scripts that
# call FL-AI's own public API.
FLASHLEARN_API_KEY=fl_pub_your-public-api-key

# ─── File Size Limits (in bytes) ─────────────────────────────────────────────
PDF_MAX_SIZE_BYTES=52428800
IMAGE_MAX_SIZE_BYTES=10485760
AUDIO_MAX_SIZE_BYTES=104857600
VIDEO_MAX_SIZE_BYTES=209715200

# ─── File Count Limits ───────────────────────────────────────────────────────
IMAGE_MAX_FILES=10

# ─── Flashcard Generation Limits ─────────────────────────────────────────────
FLASHCARD_MIN=5
FLASHCARD_MAX=50
